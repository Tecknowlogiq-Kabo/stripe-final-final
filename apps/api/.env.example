# =============================================================================
# Stripe API — Environment Variables
# =============================================================================
# Copy to .env and fill in real values.
# cp .env.example .env
#
# Never commit real secrets. .env is gitignored.
# In production, set these in PM2 ecosystem.config.js or Docker env.

# --- Runtime ---
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# --- Oracle Database ---
ORACLE_USER=stripe_app
ORACLE_PASSWORD=change_me
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XEPDB1

# --- Stripe ---
# Secret key from Stripe Dashboard → Developers → API keys
# Test: sk_test_...  Live: sk_live_...
STRIPE_SECRET_KEY=sk_test_your_key_here
# Webhook signing secret from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
# Stripe API version (ISO date from https://stripe.com/docs/upgrades)
STRIPE_API_VERSION=2026-03-25.dahlia

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth (JWT) ---
# Min 32 characters. Generate: openssl rand -hex 32
JWT_SECRET=change_me_min_32_chars_xxxxxxxxxxxxxxxxxxx

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Rate Limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Logging ---
LOG_LEVEL=info          # error | warn | info | debug | verbose
LOG_FORMAT=json         # json (prod) | pretty (dev)

# --- Encryption ---
# Min 32 characters for AES-256. Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# --- AWS / S3 ---
# AWS credentials for S3 file storage (trustId approval flow)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=stripe-trust-files
# Optional: key prefix for trustId-uploaded files
S3_TRUST_PREFIX=trust-approved/

# --- TrustId ---
# JWT secret used specifically for trustId tokens (guest links).
# If not set, falls back to JWT_SECRET.
TRUST_JWT_SECRET=
# Default TTL for trustId tokens in seconds (24h)
TRUST_TOKEN_TTL_SECONDS=86400
# Base URL for guest link generation (points to the Next.js web app)
TRUST_GUEST_LINK_BASE_URL=http://localhost:3000

# --- OpenTelemetry ---
# Read by instrumentation.ts (runs before NestJS DI).
# OTEL_SERVICE_NAME=stripe-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1
