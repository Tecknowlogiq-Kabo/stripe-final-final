{
  "title": "RED: API Overview",
  "tags": ["stripe", "api", "red"],
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (per second)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(stripe_http_requests_total[1m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(stripe_http_errors_total{status_code=~\"5..\"}[1m])) by (route) / sum(rate(stripe_http_requests_total[1m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "P50/P95/P99 Latency",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(stripe_http_request_duration_seconds_bucket[1m])) by (le, route))",
          "legendFormat": "P50 {{route}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(stripe_http_request_duration_seconds_bucket[1m])) by (le, route))",
          "legendFormat": "P95 {{route}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(stripe_http_request_duration_seconds_bucket[1m])) by (le, route))",
          "legendFormat": "P99 {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "Request Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(stripe_http_request_duration_seconds_bucket[5m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Request Volume by Status Code",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(stripe_http_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Rate by Endpoint (4xx + 5xx)",
      "type": "table",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(stripe_http_errors_total[15m])) by (route, status_code) / sum(rate(stripe_http_requests_total[15m])) by (route, status_code)",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    }
  ]
}
